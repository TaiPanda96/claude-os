{
  "name": "@claude-os/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.json && concurrently --names server,vite,tsc,electron \"bun run ../../packages/server/src/index.ts\" \"vite\" \"tsc -p tsconfig.json --watch\" \"sleep 2 && electron . --dev\"",
    "build": "vite build && tsc -p tsconfig.json",
    "start": "electron .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.renderer.json"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^34.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.13.0"
  }
}