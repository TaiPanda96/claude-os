{
  "name": "@claude-os/server",
  "version": "0.1.0",
  "private": true,
  "description": "Local Hono server — serves session data at localhost:7842.",
  "type": "module",
  "scripts": {
    "dev": "bun run --env-file ../../.env --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@claude-os/core": "workspace:*",
    "hono": "^4.2.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.4.0"
  }
}
