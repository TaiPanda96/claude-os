{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    // Override baseUrl to point to the monorepo root, so that path aliases work in scripts
    "baseUrl": "..",
    "ignoreDeprecations": "5.0",
    "paths": {
      "@claude-os/core": ["packages/core/src/index.ts"],
      "@claude-os/core/*": ["packages/core/src/*"]
    },
    "noEmit": true
  },
  "include": ["."]
}
